{
    "name": "ghanem/dtone",
    "description": "A package that provides an interface between Laravel and DT One DVS API",
    "keywords": ["Laravel", "PHP", "dtone", "API", "DT One", "DVS"],
    "type": "laravel-package",
    "license": "MIT",
    "autoload": {
        "psr-4": {
            "Ghanem\\Dtone\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Ghanem\\Dtone\\Tests\\": "tests/"
        }
    },
    "authors": [
        {
            "name": "Abdullah Ghanem",
            "email": "3bdullah.ghanem@gmail.com"
        }
    ],
    "require": {
        "php": "^7.2.5|^8.0",
        "guzzlehttp/guzzle": "^6.3|^7.0",
        "illuminate/http": "^7.0|^8.0|^9.0|^10.0|^11.0|^12.0",
        "illuminate/support": "^7.0|^8.0|^9.0|^10.0|^11.0|^12.0"
    },
    "require-dev": {
        "orchestra/testbench": "^5.0|^6.0|^7.0|^8.0|^9.0|^10.0",
        "phpunit/phpunit": "^8.4|^9.0|^10.0|^11.0"
    },
    "extra": {
        "laravel": {
            "providers": [
                "Ghanem\\Dtone\\DtoneServiceProvider"
            ],
            "aliases": {
                "Dtone": "Ghanem\\Dtone\\Facades\\Dtone"
            }
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "scripts": {
        "test": "vendor/bin/phpunit",
        "test-f": "vendor/bin/phpunit --filter"
    }
}
